# FNM Data Files — NDA-restricted, never commit
*.raw
*.RAW
*.csv
*.CSV
*.parquet
*.m

# Intermediate and reference output directories
intermediate/**
reference/**
!reference/
!reference/*/
!reference/**/summary_*.json
!reference/cleaned/intermediate/
!reference/cleaned/intermediate/*.csv
!reference/cleaned/intermediate/manifest.json

# Allow tracked infrastructure files
!manifest.json
!README.md
!**/README.md
!scripts/**/*.py
!scripts/**/*.m
!docs/**/*.md
!docs/**/*.json
!.gitignore
